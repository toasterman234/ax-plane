{
  "name": "axplane-mvp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "concurrently -n api,worker,web -c blue,green,magenta \"pnpm --filter @axplane/api dev\" \"pnpm --filter @axplane/worker dev\" \"pnpm --filter @axplane/web dev\"",
    "dev:api": "pnpm --filter @axplane/api dev",
    "dev:worker": "pnpm --filter @axplane/worker dev",
    "dev:web": "pnpm --filter @axplane/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @axplane/db db:generate",
    "db:migrate": "pnpm --filter @axplane/db db:migrate",
    "db:seed": "pnpm --filter @axplane/db db:seed",
    "db:studio": "pnpm --filter @axplane/db db:studio"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "concurrently": "^9.1.2",
    "dotenv": "^17.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
