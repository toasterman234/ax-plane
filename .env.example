# Database
DATABASE_URL=postgres://axplane:axplane@localhost:5433/axplane

# API / Web
API_PORT=8787
NEXT_PUBLIC_API_URL=http://localhost:8787

# Worker
WORKER_POLL_MS=1500

# Ax execution
# mock = deterministic local demo mode; real = use @ax-llm/ax with a configured provider.
AXPLANE_EXECUTION_MODE=mock

# For real Ax mode, set these.
AX_PROVIDER=openai
OPENAI_API_KEY=
AX_MODEL=gpt-4o-mini
