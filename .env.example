# Database
DATABASE_URL=postgres://axplane:axplane@localhost:5433/axplane

# API / Web
API_PORT=8797
NEXT_PUBLIC_API_URL=http://localhost:8797

# Worker
WORKER_POLL_MS=1500

# Ax execution
# mock = deterministic local demo mode; real = call @ax-llm/ax through cliproxy or a provider key.
AXPLANE_EXECUTION_MODE=mock

# real mode: native = ax() tool-calling (recommended); rlm = agent() JS-runtime pipeline
AXPLANE_REAL_STRATEGY=native

# Option A — local cliproxy (same as ax-lab): http://127.0.0.1:8317/v1
AX_BASE_URL=http://127.0.0.1:8317/v1
AX_API_KEY=sk-cliproxy
AX_MODEL=gemini-3-flash

# Option B — direct OpenAI (if not using cliproxy)
AX_PROVIDER=openai
OPENAI_API_KEY=
# AX_MODEL=gpt-4o-mini

# Host tools (Steps E/F)
# Repo sandbox root for repo.* and shell.run cwd defaults
AXPLANE_REPO_ROOT=
# Markdown docs root for docs.search (defaults to {AXPLANE_REPO_ROOT}/docs)
AXPLANE_DOCS_ROOT=
# Shell command timeout in ms (default 30000)
AXPLANE_SHELL_TIMEOUT_MS=30000

# GitHub tools (read + write; write tools require approval)
GITHUB_TOKEN=
# or GH_TOKEN=
GITHUB_REPO=owner/repo
